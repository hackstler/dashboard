# URL del backbone API
VITE_API_URL=http://localhost:3000

# Auth strategy — must match AUTH_STRATEGY in the backbone
VITE_AUTH_STRATEGY=password          # password | firebase

# Firebase (solo cuando VITE_AUTH_STRATEGY=firebase)
# VITE_FIREBASE_API_KEY=AIzaSy...
# VITE_FIREBASE_AUTH_DOMAIN=my-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=my-project
